# ============================
# Ghost AI — Environment Config
# ============================
# Copy to .env and fill in values

# --- Database ---
POSTGRES_PASSWORD=change_me_strong_password_here
DATABASE_URL=postgresql+asyncpg://ghost:${POSTGRES_PASSWORD}@postgres:5432/ghost_ai

# --- Redis ---
REDIS_PASSWORD=change_me_redis_password
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379

# --- App ---
SECRET_KEY=change_me_random_64_chars_min_here_1234567890abcdef
JWT_SECRET=change_me_jwt_secret_also_64_chars_minimum_random
JWT_EXPIRE_DAYS=30
DEBUG=false

# --- Telegram ---
# Get from @BotFather
BOT_TOKEN=1234567890:AABBCCDDEEFFaabbccddeeff-your-bot-token
BOT_WEBHOOK_SECRET=random_webhook_secret_string
MINIAPP_URL=https://ghostai.ru/app

# --- OAuth: Google ---
# https://console.developers.google.com/
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=https://ghostai.ru/api/auth/google/callback

# --- OAuth: Yandex ---
# https://oauth.yandex.ru/
YANDEX_CLIENT_ID=your_yandex_client_id
YANDEX_CLIENT_SECRET=your_yandex_client_secret
YANDEX_REDIRECT_URI=https://ghostai.ru/api/auth/yandex/callback

# --- LLM Providers ---
# Premium: OpenAI or compatible
LLM_PREMIUM_API_KEY=sk-your-openai-api-key
LLM_PREMIUM_BASE_URL=https://api.openai.com/v1
LLM_PREMIUM_MODEL=gpt-4o

# Economy: Together AI / Groq / etc (OpenAI-compatible)
LLM_ECONOMY_API_KEY=your-together-api-key
LLM_ECONOMY_BASE_URL=https://api.together.xyz/v1
LLM_ECONOMY_MODEL=meta-llama/Llama-3.1-70B-Instruct

# --- Image Generation ---
# Stability AI
IMAGE_API_KEY=sk-your-stability-api-key
IMAGE_API_URL=https://api.stability.ai

# --- Voice ---
# Uses OpenAI Whisper + TTS (same key as premium usually)
WHISPER_API_KEY=sk-your-openai-api-key
TTS_API_KEY=sk-your-openai-api-key
TTS_VOICE_ID=alloy

# --- Storage (S3 compatible) ---
# Option 1: Yandex Object Storage
S3_ENDPOINT=https://storage.yandexcloud.net
S3_BUCKET=ghost-ai-uploads
S3_ACCESS_KEY=your_yandex_s3_access_key
S3_SECRET_KEY=your_yandex_s3_secret_key

# Option 2: MinIO self-hosted (uncomment)
# S3_ENDPOINT=http://minio:9000
# S3_BUCKET=ghost-ai
# S3_ACCESS_KEY=minioadmin
# S3_SECRET_KEY=minioadmin

# --- Payments ---
PAYMENT_PROVIDER=yookassa
YOOKASSA_SHOP_ID=your_shop_id
YOOKASSA_SECRET_KEY=your_yookassa_secret
PAYMENT_RETURN_URL=https://ghostai.ru/payment/success

# --- Admin ---
ADMIN_SECRET_KEY=super_secret_admin_key_change_this

# --- CORS ---
CORS_ORIGINS=["https://ghostai.ru","https://www.ghostai.ru"]

# --- Next.js ---
NEXT_PUBLIC_API_URL=https://ghostai.ru
API_URL=http://api:8000
